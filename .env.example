# Скопируйте этот файл в .env и заполните значения
# Windows: copy .env.example .env

# ─── TELEGRAM (уведомления о заявках) ─────────────────────
# 1. Напишите @BotFather в Telegram → /newbot → получите токен
# 2. Напишите своему новому боту любое сообщение
# 3. Откройте https://api.telegram.org/bot<ТОКЕН>/getUpdates
#    и возьмите оттуда chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── АДМИН-ДОСТУП ─────────────────────────────────────────
# Придумайте длинный секретный токен (например 32+ случайных символа).
# Он нужен для входа на /admin и для админ-эндпоинтов API.
ADMIN_TOKEN=
