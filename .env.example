# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

PORT=3001

# ─── TELEGRAM (основной канал) ────────────────────────────
# 1. Напишите @BotFather в Telegram → /newbot → получите токен
# 2. Напишите своему новому боту любое сообщение
# 3. Откройте https://api.telegram.org/bot<ТОКЕН>/getUpdates
#    и возьмите оттуда chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── EMAIL (опционально, через SMTP) ──────────────────────
# Пример для Яндекс.Почты: smtp.yandex.ru, порт 465,
# пароль — «пароль приложения» из настроек безопасности
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_TO=
